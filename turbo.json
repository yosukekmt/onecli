{
  "$schema": "https://v2-7-6.turborepo.dev/schema.json",
  "ui": "tui",
  "globalEnv": ["NODE_ENV", "NEXT_PUBLIC_EDITION", "APP_VERSION"],
  "globalPassThroughEnv": [
    "DATABASE_URL",
    "EDITION",
    "APP_URL",
    "API_URL",
    "COGNITO_CLIENT_ID",
    "COGNITO_DOMAIN",
    "COGNITO_USER_POOL_ID",
    "NEXTAUTH_URL",
    "NEXTAUTH_SECRET",
    "NEXT_PUBLIC_COGNITO_USER_POOL_ID",
    "NEXT_PUBLIC_COGNITO_CLIENT_ID",
    "NEXT_PUBLIC_COGNITO_DOMAIN",
    "AWS_REGION",
    "NEXT_RUNTIME",
    "STRIPE_SECRET_KEY",
    "STRIPE_PRO_PRICE_ID",
    "STRIPE_TEAM_BASE_PRICE_ID",
    "STRIPE_PRO_AGENT_ADDON_PRICE_ID",
    "STRIPE_TEAM_AGENT_ADDON_PRICE_ID",
    "STRIPE_WEBHOOK_SECRET",
    "GOOGLE_CLIENT_ID",
    "GOOGLE_CLIENT_SECRET",
    "OAUTH_STATE_SECRET",
    "NEXT_PUBLIC_APP_URL",
    "SECRET_ENCRYPTION_KEY",
    "HOME",
    "GATEWAY_CA_PEM_FILE",
    "GATEWAY_CA_CERT",
    "KMS_KEY_ARN",
    "API_DOMAIN",
    "GATEWAY_API_DOMAIN",
    "GATEWAY_API_URL",
    "NEXT_PUBLIC_GATEWAY_API_URL",
    "GATEWAY_BASE_URL",
    "INTERNAL_API_URL",
    "GATEWAY_INTERNAL_SECRET",
    "LOG_LEVEL",
    "LOG_FORMAT",
    "AUTH_MODE",
    "MAILERCHECK_API_KEY",
    "DISCORD_WEBHOOK_URL",
    "DISCORD_REVIEW_WEBHOOK_URL",
    "ENVIRONMENT",
    "RESEND_API_KEY",
    "NEXT_PUBLIC_API_URL",
    "REDIS_HOST",
    "REDIS_PORT",
    "REDIS_USERNAME",
    "REDIS_PASSWORD",
    "CRON_SECRET_NAME",
    "ANTHROPIC_SECRET_NAME",
    "MICROSOFT_CLIENT_ID",
    "MICROSOFT_CLIENT_SECRET",
    "NOTION_CLIENT_ID",
    "NOTION_CLIENT_SECRET",
    "DROPBOX_CLIENT_ID",
    "DROPBOX_CLIENT_SECRET",
    "SUPABASE_CLIENT_ID",
    "SUPABASE_CLIENT_SECRET",
    "ZOOM_CLIENT_ID",
    "ZOOM_CLIENT_SECRET",
    "LINKEDIN_CLIENT_ID",
    "LINKEDIN_CLIENT_SECRET",
    "TRELLO_API_KEY",
    "TRELLO_API_SECRET",
    "MONDAY_CLIENT_ID",
    "MONDAY_CLIENT_SECRET",
    "ATTIO_CLIENT_ID",
    "ATTIO_CLIENT_SECRET",
    "SENTRY_CLIENT_ID",
    "SENTRY_CLIENT_SECRET",
    "HUBSPOT_CLIENT_ID",
    "HUBSPOT_CLIENT_SECRET",
    "LINEAR_CLIENT_ID",
    "LINEAR_CLIENT_SECRET",
    "FATHOM_CLIENT_ID",
    "FATHOM_CLIENT_SECRET",
    "RUST_LOG",
    "PORT",
    "ATLASSIAN_CLIENT_ID",
    "ATLASSIAN_CLIENT_SECRET"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "@onecli/gateway#build": {
      "inputs": ["src/**", "Cargo.toml", "Cargo.lock"],
      "outputs": ["target/release/**"]
    },
    "@onecli/gateway#dev": {
      "cache": false,
      "persistent": true,
      "passThroughEnv": [
        "EDITION",
        "DATABASE_URL",
        "SECRET_ENCRYPTION_KEY",
        "KMS_KEY_ARN",
        "AWS_REGION",
        "REDIS_HOST",
        "REDIS_PORT",
        "REDIS_PASSWORD",
        "REDIS_TLS",
        "COGNITO_USER_POOL_ID",
        "POSTHOG_API_KEY",
        "POSTHOG_HOST",
        "MICROSOFT_CLIENT_ID",
        "MICROSOFT_CLIENT_SECRET",
        "NOTION_CLIENT_ID",
        "NOTION_CLIENT_SECRET",
        "DROPBOX_CLIENT_ID",
        "DROPBOX_CLIENT_SECRET",
        "SUPABASE_CLIENT_ID",
        "SUPABASE_CLIENT_SECRET",
        "ZOOM_CLIENT_ID",
        "ZOOM_CLIENT_SECRET",
        "LINKEDIN_CLIENT_ID",
        "LINKEDIN_CLIENT_SECRET",
        "MONDAY_CLIENT_ID",
        "MONDAY_CLIENT_SECRET",
        "ATTIO_CLIENT_ID",
        "ATTIO_CLIENT_SECRET",
        "SENTRY_CLIENT_ID",
        "SENTRY_CLIENT_SECRET",
        "HUBSPOT_CLIENT_ID",
        "HUBSPOT_CLIENT_SECRET",
        "LINEAR_CLIENT_ID",
        "LINEAR_CLIENT_SECRET",
        "FATHOM_CLIENT_ID",
        "FATHOM_CLIENT_SECRET"
      ]
    },
    "@onecli/gateway#check": {
      "inputs": ["src/**", "Cargo.toml"]
    },
    "@onecli/gateway#check-types": {
      "inputs": ["src/**", "Cargo.toml", "Cargo.lock"],
      "outputs": []
    },
    "@onecli/gateway#lint": {
      "inputs": ["src/**", "Cargo.toml"],
      "outputs": []
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "lint:fix": {
      "dependsOn": ["^lint:fix"],
      "cache": false
    },
    "check-types": {
      "dependsOn": ["^build", "^check-types"]
    },
    "test": {
      "cache": false
    },
    "@onecli/gateway#test": {
      "inputs": ["src/**", "tests/**", "Cargo.toml", "Cargo.lock"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
